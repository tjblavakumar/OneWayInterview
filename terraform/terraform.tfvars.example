# ─── Required ────────────────────────────────────────────────
# Name of an existing EC2 key pair in the target AWS account/region.
# Create one in: AWS Console → EC2 → Key Pairs → Create key pair
key_pair_name = "your-key-pair-name"

# ─── Optional (defaults shown) ───────────────────────────────
# aws_region    = "us-east-1"
# instance_type = "t3.small"
# volume_size   = 20
# app_name      = "oneway-interview"
# server_port   = 5001
# enable_ssh    = true
# ssh_cidr_blocks = ["0.0.0.0/0"]   # Restrict to your IP: ["1.2.3.4/32"]

# ─── Safety (optional) ──────────────────────────────────────
# Prevent accidental deployment to the wrong account
# allowed_account_ids = ["051570254217"]
