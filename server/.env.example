PORT=5001
NODE_ENV=development

# Base URLs for link generation
ADMIN_APP_URL=http://localhost:3001
CANDIDATE_APP_URL=http://localhost:3002

# Storage mode: "local" or "s3"
STORAGE_MODE=local
LOCAL_UPLOAD_DIR=./uploads

# Email mode: "console" or "smtp" or "ses"
EMAIL_MODE=console

# SMTP settings (for dev, use Ethereal: https://ethereal.email)
# SMTP_HOST=smtp.ethereal.email
# SMTP_PORT=587
# SMTP_USER=your_user
# SMTP_PASS=your_pass

# AWS settings (for production)
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=oneway-interview-videos
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
